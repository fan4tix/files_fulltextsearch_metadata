<info xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:noNamespaceSchemaLocation="https://apps.nextcloud.com/schema/apps/info.xsd">
  <id>files_fulltextsearch_metadata</id>
  <name>Full text search - Files - Metadata</name>
  <summary>Index image, audio and video metadata for full text search</summary>
  <description><![CDATA[

Extension to the Full text search - Files app that extracts image metadata
(EXIF, IPTC and XMP where available) and audio/video tag metadata (ID3/container fields)
and injects it into the full text index.
  ]]></description>
  <version>0.1.1</version>
  <licence>agpl</licence>
  <author>Martin Schörner</author>
  <website>https://github.com/fan4tix/files_fulltextsearch_metadata</website>
  <repository type="git">https://github.com/fan4tix/files_fulltextsearch_metadata.git</repository>
  <screenshot>https://raw.githubusercontent.com/nextcloud/fulltextsearch/master/screenshots/0.3.0.png</screenshot>
  <bugs>https://github.com/fan4tix/files_fulltextsearch_metadata/issues</bugs>
  <namespace>Files_FullTextSearch_Metadata</namespace>
  <category>search</category>
  <dependencies>
    <nextcloud min-version="31" max-version="34"/>
  </dependencies>

  <settings>
    <admin>OCA\Files_FullTextSearch_Metadata\Settings\Admin</admin>
  </settings>
</info>
